cat > .gitignore << 'EOF'
# Credentials & Tokens
.env
*.env
!.env.example
.cache/
.huggingface/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.whl

# Virtual environments
venv/
env/
cliassist/
ENV/
.venv/

# User data (privacy)
memory/
*.db
*.sqlite
*.sqlite3
search_state.json
domain_knowledge.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
logs/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Model cache
models/
checkpoints/
*.pth
*.pt
*.ckpt
